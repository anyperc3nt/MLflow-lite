DATABASE_URL=sqlite:///./mlflow_lite.db
SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Опциональный bootstrap-админ. Если оба поля заполнены, при первом
# запуске сервиса создаётся пользователь с этим email и ролью admin.
# Повторные запуски ничего не делают.
ADMIN_EMAIL=
ADMIN_PASSWORD=
